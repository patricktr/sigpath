{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for all document windows",
  "windows": [
    "main",
    "win-*"
  ],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-destroy",
    "opener:default",
    "dialog:default"
  ]
}